<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>DOCTOR AHSAN | Precision. Care. Simplicity.</title>
  <!-- Google Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Canvas Confetti for success animations -->
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #F5F7FA;
      color: #2D3E50;
      line-height: 1.5;
      overflow-x: hidden;
    }

    /* Color variables */
    :root {
      --deep-teal: #0F4C5C;
      --electric-blue: #2D9CDB;
      --soft-mint: #9FD3C7;
      --charcoal: #2D3E50;
      --light-gray: #F5F7FA;
      --white: #FFFFFF;
      --error-red: #EF4444;
      --success-green: #10B981;
      --border-light: #E2E8F0;
    }

    /* Typography */
    h1, h2, h3, .logo, .nav-link, .card-title {
      font-family: 'Poppins', sans-serif;
    }

    /* Sticky Header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border-light);
      transition: all 0.2s ease;
    }
    .header-container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 32px;
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--deep-teal);
      letter-spacing: -0.02em;
      text-decoration: none;
      transition: transform 0.2s;
    }
    .logo i {
      margin-right: 6px;
      color: var(--electric-blue);
    }
    .nav-links {
      display: flex;
      gap: 2rem;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--charcoal);
      font-weight: 500;
      transition: color 0.2s;
      position: relative;
    }
    .nav-links a:hover, .nav-links a.active {
      color: var(--electric-blue);
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--electric-blue);
      transition: width 0.2s ease;
    }
    .nav-links a:hover::after, .nav-links a.active::after {
      width: 100%;
    }
    .header-actions {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }
    .icon-btn {
      background: none;
      border: none;
      font-size: 1.4rem;
      cursor: pointer;
      color: var(--charcoal);
      position: relative;
      transition: transform 0.2s, color 0.2s;
    }
    .icon-btn:hover {
      color: var(--electric-blue);
      transform: scale(1.05);
    }
    .cart-badge {
      position: absolute;
      top: -8px;
      right: -12px;
      background: var(--deep-teal);
      color: white;
      font-size: 0.7rem;
      font-weight: 600;
      border-radius: 40px;
      padding: 2px 6px;
      min-width: 18px;
      text-align: center;
      transition: transform 0.2s cubic-bezier(0.34, 1.2, 0.64, 1);
    }
    .bounce-animate {
      transform: scale(1.2);
    }

    /* Hero Section */
    .hero {
      background: linear-gradient(135deg, #0F4C5C, #2D9CDB);
      color: white;
      padding: 4rem 2rem;
      text-align: center;
      margin-bottom: 3rem;
    }
    .hero h1 {
      font-size: 3rem;
      font-weight: 700;
    }
    .hero p {
      font-size: 1.2rem;
      margin-top: 1rem;
      opacity: 0.9;
    }

    /* Product Grid */
    .products-section {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 32px 4rem;
    }
    .section-title {
      font-size: 2rem;
      margin-bottom: 2rem;
      font-weight: 600;
    }
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
    }

    /* Product Card (SAAS style) */
    .product-card {
      background: var(--white);
      border-radius: 24px;
      border: 1px solid var(--border-light);
      padding: 1.5rem;
      transition: all 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
      position: relative;
      animation: fadeUp 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
      opacity: 0;
      transform: translateY(20px);
    }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }
    .product-card:hover {
      transform: translateY(-8px);
      border-color: var(--electric-blue);
      box-shadow: 0 25px 35px -12px rgba(0, 0, 0, 0.15);
    }
    .card-img {
      width: 100%;
      height: 160px;
      background: #EFF3F6;
      border-radius: 16px;
      margin-bottom: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      color: var(--deep-teal);
      transition: transform 0.3s ease;
    }
    .product-card:hover .card-img {
      transform: scale(1.02);
    }
    .card-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    .rating {
      display: flex;
      align-items: center;
      gap: 6px;
      margin: 0.5rem 0;
      color: #F59E0B;
      font-size: 0.85rem;
    }
    .price {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--electric-blue);
      margin: 0.5rem 0;
    }
    .card-actions {
      display: flex;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .btn-outline {
      background: transparent;
      border: 1px solid var(--electric-blue);
      color: var(--electric-blue);
      padding: 8px 16px;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      flex: 1;
    }
    .btn-outline:hover {
      background: var(--electric-blue);
      color: white;
      transform: scale(1.02);
    }
    .icon-btn-sm {
      background: transparent;
      border: 1px solid var(--border-light);
      border-radius: 40px;
      width: 42px;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 1rem;
    }
    .icon-btn-sm:hover {
      border-color: var(--electric-blue);
      color: var(--electric-blue);
    }

    /* Drawer base */
    .drawer {
      position: fixed;
      top: 0;
      right: 0;
      width: 480px;
      max-width: 90vw;
      height: 100%;
      background: white;
      z-index: 1000;
      transform: translateX(100%);
      transition: transform 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      box-shadow: -5px 0 25px rgba(0, 0, 0, 0.1);
      display: flex;
      flex-direction: column;
      border-radius: 0;
    }
    .drawer.open {
      transform: translateX(0);
    }
    .drawer-header {
      padding: 1.5rem;
      border-bottom: 1px solid var(--border-light);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
      font-size: 1.25rem;
    }
    .drawer-body {
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem;
    }
    .drawer-footer {
      padding: 1.5rem;
      border-top: 1px solid var(--border-light);
    }
    .backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(4px);
      z-index: 999;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s;
    }
    .backdrop.active {
      opacity: 1;
      visibility: visible;
    }
    /* cart items */
    .cart-item {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border-light);
    }
    .cart-item-img {
      width: 60px;
      height: 60px;
      background: #f0f2f5;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .cart-item-details {
      flex: 1;
    }
    .quantity-selector {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 8px;
    }
    .qty-btn {
      width: 28px;
      height: 28px;
      border-radius: 20px;
      border: 1px solid var(--border-light);
      background: white;
      cursor: pointer;
    }

    /* Payment Form */
    .payment-form .form-group {
      margin-bottom: 1.2rem;
    }
    .form-group label {
      display: block;
      font-weight: 500;
      margin-bottom: 6px;
    }
    .form-group input {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid var(--border-light);
      border-radius: 14px;
      font-size: 1rem;
      transition: all 0.2s;
    }
    .form-group input:focus {
      outline: none;
      border-color: var(--electric-blue);
      box-shadow: 0 0 0 3px rgba(45,156,219,0.2);
    }
    .card-icons {
      display: flex;
      gap: 10px;
      margin-top: 8px;
    }
    .card-icons i {
      font-size: 1.8rem;
      opacity: 0.4;
      transition: opacity 0.2s;
    }
    .card-icons i.active {
      opacity: 1;
    }
    .error-msg {
      color: var(--error-red);
      font-size: 0.75rem;
      margin-top: 4px;
    }
    .shake {
      animation: shake 0.2s ease-in-out 0s 1;
    }
    @keyframes shake {
      0%,100%{ transform: translateX(0); }
      25%{ transform: translateX(-4px); }
      75%{ transform: translateX(4px); }
    }
    .btn-primary {
      background: var(--electric-blue);
      color: white;
      border: none;
      padding: 14px;
      width: 100%;
      border-radius: 40px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-primary:active {
      transform: scale(0.98);
    }
    .success-check {
      text-align: center;
      padding: 2rem;
    }
    .toast {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--deep-teal);
      color: white;
      padding: 10px 20px;
      border-radius: 40px;
      z-index: 1100;
      animation: fadeSlide 2s forwards;
    }
    @keyframes fadeSlide {
      0% { opacity: 0; transform: translateX(-50%) translateY(20px); }
      15% { opacity: 1; transform: translateX(-50%) translateY(0); }
      85% { opacity: 1; transform: translateX(-50%) translateY(0); }
      100% { opacity: 0; visibility: hidden; }
    }
    @media (max-width: 768px) {
      .header-container { padding: 0 20px; height: 64px; }
      .nav-links { display: none; }
      .drawer { width: 100%; border-radius: 24px 24px 0 0; bottom: 0; top: auto; height: 90vh; transform: translateY(100%); }
      .drawer.open { transform: translateY(0); }
      .hero h1 { font-size: 2rem; }
    }
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-container">
    <a href="#" class="logo"><i class="fas fa-shield-alt"></i> DOCTOR AHSAN</a>
    <div class="nav-links">
      <a href="#" class="active">Home</a>
      <a href="#">Products</a>
      <a href="#">About</a>
      <a href="#">Contact</a>
    </div>
    <div class="header-actions">
      <button class="icon-btn" id="searchBtn"><i class="fas fa-search"></i></button>
      <button class="icon-btn" id="cartIconBtn">
        <i class="fas fa-shopping-bag"></i>
        <span id="cartCountBadge" class="cart-badge">0</span>
      </button>
      <button class="icon-btn"><i class="fas fa-user-circle"></i></button>
    </div>
  </div>
</header>

<section class="hero">
  <h1>Precision. Care. Simplicity.</h1>
  <p>Doctor‑trusted essentials — secure global checkout</p>
</section>

<main class="products-section">
  <h2 class="section-title">Featured formulas</h2>
  <div class="products-grid" id="productsGrid"></div>
</main>

<!-- Cart Drawer -->
<div id="cartDrawer" class="drawer">
  <div class="drawer-header">
    <span>Your Cart (<span id="cartDrawerCount">0</span>)</span>
    <button class="icon-btn close-drawer"><i class="fas fa-times"></i></button>
  </div>
  <div class="drawer-body" id="cartItemsContainer">
    <div style="text-align:center; padding:2rem;">Cart is empty</div>
  </div>
  <div class="drawer-footer">
    <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
      <strong>Subtotal</strong>
      <strong id="cartTotalPrice">$0.00</strong>
    </div>
    <button id="checkoutFromCart" class="btn-primary">Checkout →</button>
  </div>
</div>

<!-- Payment Drawer -->
<div id="paymentDrawer" class="drawer">
  <div class="drawer-header">
    <span>Secure Checkout</span>
    <button class="icon-btn close-payment"><i class="fas fa-times"></i></button>
  </div>
  <div class="drawer-body" id="paymentBody">
    <!-- dynamic content: order summary + form -->
  </div>
</div>

<div id="backdrop" class="backdrop"></div>

<script>
  // ---------- MOCK PRODUCTS ----------
  const products = [
    { id: 1, name: "Vitamin C Brightening Serum", price: 49.99, rating: 4.8, reviews: 124, icon: "🍊", stock: true },
    { id: 2, name: "Hydrating HA Moisturizer", price: 39.99, rating: 4.9, reviews: 89, icon: "💧", stock: true },
    { id: 3, name: "SPF 50 Mineral Sunscreen", price: 32.99, rating: 4.7, reviews: 210, icon: "☀️", stock: true },
    { id: 4, name: "Retinol Night Renewal", price: 54.99, rating: 4.8, reviews: 156, icon: "🌙", stock: true }
  ];

  let cart = []; // { id, name, price, quantity, imageIcon }
  let activeDrawer = null;
  let directPurchaseItem = null; // used for quick buy

  // helper functions
  function saveCart() {
    localStorage.setItem('doctorCart', JSON.stringify(cart));
    updateCartUI();
  }

  function loadCart() {
    const saved = localStorage.getItem('doctorCart');
    if(saved) cart = JSON.parse(saved);
    updateCartUI();
  }

  function updateCartUI() {
    const count = cart.reduce((sum, i) => sum + i.quantity, 0);
    const badge = document.getElementById('cartCountBadge');
    if(badge) badge.innerText = count;
    const drawerCountSpan = document.getElementById('cartDrawerCount');
    if(drawerCountSpan) drawerCountSpan.innerText = count;
    const total = cart.reduce((sum, i) => sum + (i.price * i.quantity), 0);
    const totalEl = document.getElementById('cartTotalPrice');
    if(totalEl) totalEl.innerText = `$${total.toFixed(2)}`;
    renderCartItems();
    if(count === 0 && activeDrawer === 'cart') closeDrawers();
  }

  function renderCartItems() {
    const container = document.getElementById('cartItemsContainer');
    if(!container) return;
    if(cart.length === 0) {
      container.innerHTML = '<div style="text-align:center; padding:2rem;">Your cart is empty</div>';
      return;
    }
    container.innerHTML = cart.map(item => `
      <div class="cart-item" data-id="${item.id}">
        <div class="cart-item-img" style="font-size:2rem;">${item.imageIcon || '🧴'}</div>
        <div class="cart-item-details">
          <div><strong>${item.name}</strong></div>
          <div>$${item.price}</div>
          <div class="quantity-selector">
            <button class="qty-btn" data-id="${item.id}" data-delta="-1">-</button>
            <span>${item.quantity}</span>
            <button class="qty-btn" data-id="${item.id}" data-delta="1">+</button>
            <button class="qty-btn" style="color:#EF4444;" data-id="${item.id}" data-remove="true">🗑️</button>
          </div>
        </div>
      </div>
    `).join('');
    document.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = parseInt(btn.dataset.id);
        const delta = btn.dataset.delta ? parseInt(btn.dataset.delta) : 0;
        if(btn.dataset.remove) {
          cart = cart.filter(i => i.id !== id);
          saveCart();
          showToast("Item removed");
        } else if(delta) {
          const idx = cart.findIndex(i => i.id === id);
          if(idx !== -1) {
            const newQty = cart[idx].quantity + delta;
            if(newQty <= 0) cart.splice(idx,1);
            else cart[idx].quantity = newQty;
            saveCart();
          }
        }
        updateCartUI();
      });
    });
  }

  function addToCart(product, qty = 1) {
    const existing = cart.find(i => i.id === product.id);
    if(existing) existing.quantity += qty;
    else cart.push({ ...product, quantity: qty, imageIcon: product.icon });
    saveCart();
    const badge = document.getElementById('cartCountBadge');
    if(badge) badge.classList.add('bounce-animate');
    setTimeout(() => badge?.classList.remove('bounce-animate'), 200);
    showToast(`Added ${product.name}`);
  }

  function showToast(msg) {
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.innerText = msg;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 2000);
  }

  function closeDrawers() {
    document.getElementById('cartDrawer').classList.remove('open');
    document.getElementById('paymentDrawer').classList.remove('open');
    document.getElementById('backdrop').classList.remove('active');
    activeDrawer = null;
    document.body.style.overflow = '';
  }

  function openDrawer(drawerId) {
    closeDrawers();
    const drawer = document.getElementById(drawerId);
    drawer.classList.add('open');
    document.getElementById('backdrop').classList.add('active');
    activeDrawer = drawerId;
    document.body.style.overflow = 'hidden';
  }

  // Payment drawer setup
  function renderPaymentDrawerContent(mode, itemsData, totalAmount) {
    const container = document.getElementById('paymentBody');
    let summaryHtml = '';
    if(mode === 'direct' && directPurchaseItem) {
      summaryHtml = `
        <div style="background:#F5F7FA; border-radius:20px; padding:1rem; margin-bottom:1.5rem;">
          <div style="display:flex; gap:1rem;"><div style="font-size:2rem;">${directPurchaseItem.icon}</div>
          <div><strong>${directPurchaseItem.name}</strong><br>$${directPurchaseItem.price}</div></div>
          <div>Quantity: 1</div>
          <div><strong>Total: $${directPurchaseItem.price.toFixed(2)}</strong></div>
        </div>
      `;
    } else {
      summaryHtml = `<div style="background:#F5F7FA; border-radius:20px; padding:1rem; margin-bottom:1rem;">
        <strong>Order summary (${cart.reduce((a,b)=>a+b.quantity,0)} items)</strong><br>
        ${cart.map(i=>`${i.name} x${i.quantity} – $${(i.price*i.quantity).toFixed(2)}`).join('<br>')}
        <hr><strong>Total: $${totalAmount.toFixed(2)}</strong>
      </div>`;
    }
    container.innerHTML = `
      <div>${summaryHtml}</div>
      <div class="payment-form">
        <div class="form-group">
          <label>Card Number</label>
          <input type="text" id="cardNumber" placeholder="1234 5678 9012 3456" maxlength="19">
          <div class="card-icons" id="cardIcons">
            <i class="fab fa-cc-visa"></i> <i class="fab fa-cc-mastercard"></i> <i class="fab fa-cc-amex"></i> <i class="fab fa-cc-discover"></i> <i class="fab fa-cc-jcb"></i>
          </div>
          <div id="cardError" class="error-msg"></div>
        </div>
        <div style="display:flex; gap:1rem;">
          <div class="form-group" style="flex:1"><label>Expiry (MM/YY)</label><input id="expiry" placeholder="MM/YY" maxlength="5"></div>
          <div class="form-group" style="flex:1"><label>CVV</label><input id="cvv" placeholder="123" maxlength="4"></div>
        </div>
        <div class="form-group"><label>Cardholder Name</label><input id="cardName" placeholder="John Smith"></div>
        <button id="payNowBtn" class="btn-primary">Pay Now</button>
      </div>
    `;
    attachPaymentValidation(mode);
  }

  function attachPaymentValidation(mode) {
    const cardNum = document.getElementById('cardNumber');
    const expiry = document.getElementById('expiry');
    const cvv = document.getElementById('cvv');
    const payBtn = document.getElementById('payNowBtn');
    const cardIcons = document.querySelectorAll('.card-icons i');
    function getCardType(number) {
      const cleaned = number.replace(/\s/g,'');
      if(/^4/.test(cleaned)) return 'visa';
      if(/^5[1-5]/.test(cleaned)) return 'mastercard';
      if(/^3[47]/.test(cleaned)) return 'amex';
      if(/^6(?:011|5)/.test(cleaned)) return 'discover';
      if(/^62/.test(cleaned)) return 'unionpay';
      return null;
    }
    function formatCardNumber(value) {
      return value.replace(/\s/g,'').replace(/(\d{4})/g,'$1 ').trim();
    }
    cardNum.addEventListener('input', (e) => {
      let val = e.target.value.replace(/\s/g,'').replace(/\D/g,'').slice(0,16);
      if(getCardType(val) === 'amex') val = val.slice(0,15);
      e.target.value = formatCardNumber(val);
      const type = getCardType(val);
      cardIcons.forEach(icon => icon.classList.remove('active'));
      if(type === 'visa') cardIcons[0].classList.add('active');
      else if(type === 'mastercard') cardIcons[1].classList.add('active');
      else if(type === 'amex') cardIcons[2].classList.add('active');
      else if(type === 'discover') cardIcons[3].classList.add('active');
      else if(type === 'unionpay') cardIcons[4].classList.add('active');
    });
    expiry.addEventListener('input', (e) => {
      let val = e.target.value.replace(/\D/g,'');
      if(val.length >= 2) val = val.slice(0,2) + '/' + val.slice(2,4);
      e.target.value = val.slice(0,5);
    });
    function luhnCheck(num) {
      let sum = 0, alt = false;
      const digits = num.replace(/\s/g,'').split('').reverse();
      for(let i=0;i<digits.length;i++){
        let n = parseInt(digits[i]);
        if(alt) n*=2;
        if(n>9) n-=9;
        sum+=n;
        alt=!alt;
      }
      return sum%10===0;
    }
    function validateForm() {
      let valid = true;
      const cardRaw = cardNum.value.replace(/\s/g,'');
      if(cardRaw.length < 13 || !luhnCheck(cardRaw)) {
        document.getElementById('cardError').innerText = 'Invalid card number';
        cardNum.classList.add('shake'); setTimeout(()=>cardNum.classList.remove('shake'),300);
        valid=false;
      } else document.getElementById('cardError').innerText = '';
      const exp = expiry.value;
      if(!/^\d{2}\/\d{2}$/.test(exp)) valid=false;
      if(cvv.value.length < 3) valid=false;
      return valid;
    }
    payBtn.onclick = (e) => {
      e.preventDefault();
      if(!validateForm()) {
        showToast("Please check card details");
        return;
      }
      payBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Processing...';
      payBtn.disabled = true;
      setTimeout(() => {
        // success simulation
        canvasConfetti({ particleCount: 120, spread: 70, origin: { y: 0.6 } });
        const successHtml = `<div class="success-check"><i class="fas fa-check-circle" style="font-size:4rem; color:#10B981; animation: bounce 0.5s;"></i><h3>Payment Successful!</h3><p>Thank you, Doctor Ahsan.</p><button id="continueBtn" class="btn-primary" style="margin-top:1rem;">Continue Shopping</button></div>`;
        document.getElementById('paymentBody').innerHTML = successHtml;
        document.getElementById('continueBtn')?.addEventListener('click', () => {
          closeDrawers();
          if(mode === 'direct') directPurchaseItem = null;
          else { cart = []; saveCart(); updateCartUI(); }
        });
      }, 1200);
    };
  }

  function openPaymentForCart() {
    const total = cart.reduce((s,i)=>s+(i.price*i.quantity),0);
    if(cart.length === 0) { showToast("Cart is empty"); return; }
    directPurchaseItem = null;
    renderPaymentDrawerContent('cart', cart, total);
    openDrawer('paymentDrawer');
  }
  function openPaymentForDirect(product) {
    directPurchaseItem = product;
    renderPaymentDrawerContent('direct', null, product.price);
    openDrawer('paymentDrawer');
  }

  // Render product cards
  function renderProducts() {
    const grid = document.getElementById('productsGrid');
    grid.innerHTML = '';
    products.forEach((prod, idx) => {
      const card = document.createElement('div');
      card.className = 'product-card';
      card.style.animationDelay = `${idx * 0.05}s`;
      card.innerHTML = `
        <div class="card-img"><i class="fas fa-capsules" style="font-size:3rem; color:#0F4C5C;"></i> ${prod.icon}</div>
        <div class="card-title">${prod.name}</div>
        <div class="rating"><i class="fas fa-star"></i> ${prod.rating} (${prod.reviews} reviews)</div>
        <div class="price">$${prod.price}</div>
        <div class="card-actions">
          <button class="btn-outline quick-buy" data-id="${prod.id}">Quick Buy</button>
          <button class="icon-btn-sm add-cart" data-id="${prod.id}"><i class="fas fa-cart-plus"></i></button>
        </div>
      `;
      grid.appendChild(card);
    });
    document.querySelectorAll('.quick-buy').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = parseInt(btn.dataset.id);
        const product = products.find(p => p.id === id);
        if(product) openPaymentForDirect(product);
      });
    });
    document.querySelectorAll('.add-cart').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = parseInt(btn.dataset.id);
        const product = products.find(p => p.id === id);
        if(product) addToCart(product, 1);
      });
    });
  }

  // Event listeners
  document.getElementById('cartIconBtn').addEventListener('click', () => openDrawer('cartDrawer'));
  document.getElementById('checkoutFromCart').addEventListener('click', () => {
    closeDrawers();
    openPaymentForCart();
  });
  document.querySelectorAll('.close-drawer, .close-payment').forEach(btn => {
    btn.addEventListener('click', closeDrawers);
  });
  document.getElementById('backdrop').addEventListener('click', closeDrawers);
  document.getElementById('searchBtn')?.addEventListener('click', () => showToast("Search (demo) — product grid active"));

  loadCart();
  renderProducts();
</script>
</body>
</html>
